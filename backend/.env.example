# VibeLegal Backend Environment Configuration
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/vibelegal

# OpenAI API Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=<your_openai_api_key>

# JWT Secret for Authentication
# Generate a secure random string for production
JWT_SECRET=<your_jwt_secret>

# Optional: Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# Stripe Configuration (Payment Processing)
# Get these from your Stripe Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Webhook Secret (for webhook signature verification)
# Get this when you create a webhook endpoint in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (Create these in your Stripe Dashboard under Products)
# Example: Go to Products -> Add Product -> Add Pricing -> Copy Price ID
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly_stripe_id
STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly_stripe_id
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_enterprise_monthly_stripe_id
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_enterprise_yearly_stripe_id

# Frontend URL (for payment success/cancel redirects)
FRONTEND_URL=http://localhost:5173

# Optional: Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

